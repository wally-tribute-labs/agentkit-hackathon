# World Developer Portal — create app at https://developer.worldcoin.org
NEXT_PUBLIC_APP_ID=app_staging_...

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# HMAC for wallet nonce signing
HMAC_SECRET_KEY=generate-with-openssl-rand-hex-32

# x402 payment configuration
# EVM wallet address that receives USDC payments from agent queries
EVM_ADDRESS=0x...
# CDP facilitator URL (use Coinbase's hosted facilitator)
FACILITATOR_URL=https://x402-facilitator.cdp.coinbase.com
# Network: base-sepolia for testnet, eip155:8453 for mainnet
X402_NETWORK=eip155:84532

# Dev convenience — set to "true" to bypass World ID verification locally
# Never set this in production
NEXT_PUBLIC_DEV_SKIP_VERIFY=true
